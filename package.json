{
  "name": "traveller-tools",
  "version": "0.1.0",
  "private": true,
  "description": "Tools for running Mongoose Traveller 2nd Edition (MgT2)",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "tsx packages/tui/src/cli.tsx",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . && prettier --check .",
    "format": "prettier --write .",
    "typecheck": "tsc --build",
    "build": "tsc --build",
    "dev:web": "vite --config packages/web/vite.config.ts",
    "build:web": "vite build --config packages/web/vite.config.ts",
    "preview:web": "vite preview --config packages/web/vite.config.ts"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.12",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT"
}
