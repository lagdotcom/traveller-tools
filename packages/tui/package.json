{
  "name": "@traveller-tools/tui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Interactive Ink TUI for the Traveller tools",
  "bin": {
    "traveller-tools": "./dist/cli.js"
  },
  "main": "./dist/mount.js",
  "types": "./dist/mount.d.ts",
  "exports": {
    ".": {
