    "build": "tsc --build",
    "start": "tsx src/cli.tsx"
  },
  "dependencies": {
    "@inkjs/ui": "^2.0.0",
    "@traveller-tools/core": "0.1.0",
    "ink": "^5.1.0",
    "react": "^18.3.1"
  },
  "license": "MIT",
  "devDependencies": {
    "ink-testing-library": "^4.0.0",
    "strip-ansi": "^7.2.0"
  }
}
